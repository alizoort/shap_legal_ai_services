{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shap-legal-ai.local/shap_legal_ai_services/instruction-manifest.schema.json",
  "title": "InstructionManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "scope",
    "bounded_context",
    "use_cases",
    "commands",
    "queries",
    "events_emitted",
    "events_consumed",
    "api_endpoints",
    "data_ownership",
    "dependencies",
    "security_constraints",
    "observability",
    "test_plan"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3
    },
    "scope": {
      "type": "string",
      "enum": [
        "feature",
        "service",
        "microservice"
      ]
    },
    "bounded_context": {
      "type": "string",
      "minLength": 2
    },
    "description": {
      "type": "string"
    },
    "use_cases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "events_emitted": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "events_consumed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "api_endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "method",
          "path",
          "purpose"
        ],
        "properties": {
          "method": {
            "type": "string",
            "enum": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "data_ownership": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service_database",
        "owned_entities",
        "cross_service_access"
      ],
      "properties": {
        "service_database": {
          "type": "string",
          "minLength": 1
        },
        "owned_entities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "cross_service_access": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "security_constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logs",
        "metrics",
        "alerts"
      ],
      "properties": {
        "logs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "alerts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "test_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "contract",
        "integration",
        "acceptance"
      ],
      "properties": {
        "unit": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contract": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "integration": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "acceptance": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rollout": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
