# Local backend development profile.
# Source this file before running uvicorn:
#   set -a && source .env && set +a

# Docker Compose database inputs
DATASOURCE_URL=postgresql://app:app@db:5432
DATASOURCE_USERNAME=app
DATASOURCE_PASSWORD=app
ADMIN_DBNAME=postgres
LEGAL_AI_DBNAME=legal_ai_db

# Local uvicorn development inputs
ENVIRONMENT=dev
ALLOW_DIRECT_PACKAGE_IMPORTS=true
ALLOW_WEAK_GATEWAY_USER_CONTEXT_SECRET_IN_LOCAL=true
LEGAL_AI_SERVICE_BASE_URL=http://127.0.0.1:8103
LEGAL_AI_DATABASE_URL=postgresql://app:app@127.0.0.1:5437/legal_ai_db

# Gateway/auth and browser access
GATEWAY_USER_CONTEXT_SECRET=shap-legal-ai-local-user-context-secret
GATEWAY_TRUST_USER_CONTEXT_HEADERS=true
REQUIRE_SIGNED_USER_CONTEXT=false
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Optional OpenAI commentary
LEGAL_AI_ENABLE_COMMENTARY=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=replace-with-your-openai-api-key
