DATASOURCE_URL=postgresql://app:app@db:5432
DATASOURCE_USERNAME=app
DATASOURCE_PASSWORD=app
ADMIN_DBNAME=postgres
LEGAL_AI_DBNAME=legal_ai_db
GATEWAY_USER_CONTEXT_SECRET=shap-legal-ai-local-user-context-secret
GATEWAY_TRUST_USER_CONTEXT_HEADERS=true
REQUIRE_SIGNED_USER_CONTEXT=false
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
ENVIRONMENT=local

LEGAL_AI_ENABLE_COMMENTARY=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=replace-with-your-openai-api-key
